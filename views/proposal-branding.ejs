<!-- ════════════════════════════════════════════════
     4. PORTFOLIO
════════════════════════════════════════════════ -->
<section class="section" style="border-top:1px solid #111;">
  <div class="container">
    <div style="margin-bottom:3.5rem;">
      <div class="sec-num reveal" style="float:left;margin-right:1.5rem;line-height:.85;">04</div>
      <p class="label reveal" style="margin-bottom:.5rem;">Portfólio</p>
      <h2 class="reveal" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;margin:0;line-height:1.1;clear:both;">Nosso Trabalho</h2>
    </div>

    <!-- 4a. REDES SOCIAIS -->
    <% if (assets.redesSociais.length) { %>
    <div class="port-section reveal">
      <div class="port-heading">
        <div><div class="port-tag">Portfólio</div><h3>Redes Sociais</h3></div>
        <div class="port-desc">Conteúdo pensado para Instagram e TikTok —<br>vídeos, estáticos e stories que geram resultado.</div>
      </div>
      <div class="collapsible-grid" id="cg-redes">
        <div class="masonry" data-gallery="redesSociais">
          <% assets.redesSociais.forEach((img,i)=>{ %>
            <div class="masonry-item" data-gallery="redesSociais" data-index="<%= i %>"><img src="<%= img %>" alt="" loading="lazy"></div>
          <% }) %>
        </div>
      </div>
      <% if (assets.redesSociais.length > 8) { %>
      <div style="text-align:center;">
        <button class="ver-mais-btn" data-target="cg-redes">Ver mais ↓</button>
      </div>
      <% } %>
    </div>
    <% } %>

    <!-- 4b. E-COMMERCE -->
    <% if (assets.ecommerce.length) { %>
    <div class="port-section reveal">
      <div class="port-heading">
        <div><div class="port-tag">Portfólio</div><h3>E-commerce</h3></div>
        <div class="port-desc">Imagens e artes focadas em conversão —<br>do produto à vitrine digital.</div>
      </div>
      <div class="collapsible-grid" id="cg-eco">
        <div class="eco-grid">
          <%
            const ecoBanners  = assets.ecommerce.filter(img => /banner|topo/i.test(img));
            const ecoProducts = assets.ecommerce.filter(img => !/banner|topo/i.test(img));
            const ecoMixed = [];
            let _bi = 0, _pi = 0;
            while (_pi < ecoProducts.length || _bi < ecoBanners.length) {
              const pL = ecoProducts.length - _pi;
              const bL = ecoBanners.length  - _bi;
              if (pL >= 2 && bL > 0) {
                ecoMixed.push({ img: ecoProducts[_pi++], span: 1 });
                ecoMixed.push({ img: ecoProducts[_pi++], span: 1 });
                ecoMixed.push({ img: ecoBanners[_bi++],  span: 2 });
              } else if (pL === 1 && bL > 0) {
                ecoMixed.push({ img: ecoProducts[_pi++], span: 1 });
                ecoMixed.push({ img: ecoBanners[_bi++],  span: 3 });
              } else if (pL === 0 && bL >= 2) {
                ecoMixed.push({ img: ecoBanners[_bi++], span: 2 });
                ecoMixed.push({ img: ecoBanners[_bi++], span: 2 });
              } else if (pL === 0 && bL === 1) {
                ecoMixed.push({ img: ecoBanners[_bi++], span: 4 });
              } else {
                while (_pi < ecoProducts.length) ecoMixed.push({ img: ecoProducts[_pi++], span: 1 });
                break;
              }
            }
          %>
          <% ecoMixed.forEach(item => { %>
            <div class="eco-grid-item<%= item.span > 1 ? ' span-' + item.span : '' %>"
                 data-gallery="ecommerce"
                 data-index="<%= assets.ecommerce.indexOf(item.img) %>">
              <img src="<%= item.img %>" alt="" loading="lazy">
            </div>
          <% }) %>
        </div>
      </div>
      <% if (assets.ecommerce.length > 6) { %>
      <div style="text-align:center;">
        <button class="ver-mais-btn" data-target="cg-eco">Ver mais ↓</button>
      </div>
      <% } %>
    </div>
    <% } %>

    <!-- 4c. OFF-LINE -->
    <% if (assets.offline.length) { %>
    <div class="port-section reveal">
      <div class="port-heading">
        <div><div class="port-tag">Portfólio</div><h3>Off-line</h3></div>
        <div class="port-desc">Peças para o mundo físico — banners, flyers,<br>outdoors e materiais impressos.</div>
      </div>
      <div class="collapsible-grid" id="cg-off">
        <div class="masonry cols-3" data-gallery="offline">
          <% assets.offline.forEach((img,i)=>{ %>
            <div class="masonry-item" data-gallery="offline" data-index="<%= i %>"><img src="<%= img %>" alt="" loading="lazy"></div>
          <% }) %>
        </div>
      </div>
      <% if (assets.offline.length > 6) { %>
      <div style="text-align:center;">
        <button class="ver-mais-btn" data-target="cg-off">Ver mais ↓</button>
      </div>
      <% } %>
    </div>
    <% } %>

    <!-- 4d. AUDIOVISUAL -->
    <div class="port-section reveal">
      <div class="port-heading">
        <div><div class="port-tag">Portfólio</div><h3>Audiovisual</h3></div>
        <div class="port-desc">Produção completa do roteiro à edição —<br>para redes sociais e tela grande.</div>
      </div>
      <div class="av-cards">

        <!-- Card Redes -->
        <a class="av-card" href="https://youtube.com/playlist?list=PLkVpdYag8wjEOI2IH5-_GqUoVyWm-qt4h&si=MqxlW2GDbIfbsYOb" target="_blank" rel="noopener">
          <div class="av-card-bg">
            <%
              const rAv = assets.audiovisualRedes;
              const chunk = Math.ceil(rAv.length/3)||1;
            %>
            <div class="av-card-bg-col">
              <% rAv.slice(0,chunk).concat(rAv.slice(0,chunk)).forEach(img=>{ %><img src="<%= img %>" alt="" loading="eager"><% }) %>
            </div>
            <div class="av-card-bg-col">
              <% rAv.slice(chunk,chunk*2).concat(rAv.slice(chunk,chunk*2)).forEach(img=>{ %><img src="<%= img %>" alt="" loading="eager"><% }) %>
            </div>
            <div class="av-card-bg-col">
              <% rAv.slice(chunk*2).concat(rAv.slice(chunk*2)).forEach(img=>{ %><img src="<%= img %>" alt="" loading="eager"><% }) %>
            </div>
          </div>
          <div class="av-card-overlay"></div>
          <div class="av-card-content">
            <p class="av-card-tag">Audiovisual</p>
            <h3 class="av-card-title">Redes<br>Sociais</h3>
            <p class="av-card-desc">Pensados, gravados e editados<br>para Instagram e TikTok.</p>
            <span class="av-cta"><span class="av-play"></span>Clique e assista</span>
          </div>
        </a>

        <!-- Card Eventos -->
        <a class="av-card" href="https://youtube.com/playlist?list=PLkVpdYag8wjGlNHhRgibzSKpus5ICzB5J&si=8hcHNUysiUXDH0RH" target="_blank" rel="noopener">
          <div class="av-card-bg">
            <%
              const eAv = assets.audiovisualEventos;
              const chunkE = Math.ceil(eAv.length/3)||1;
            %>
            <div class="av-card-bg-col">
              <% eAv.slice(0,chunkE).concat(eAv.slice(0,chunkE)).forEach(img=>{ %><img src="<%= img %>" alt="" loading="eager"><% }) %>
            </div>
            <div class="av-card-bg-col">
              <% eAv.slice(chunkE,chunkE*2).concat(eAv.slice(chunkE,chunkE*2)).forEach(img=>{ %><img src="<%= img %>" alt="" loading="eager"><% }) %>
            </div>
            <div class="av-card-bg-col">
              <% eAv.slice(chunkE*2).concat(eAv.slice(chunkE*2)).forEach(img=>{ %><img src="<%= img %>" alt="" loading="eager"><% }) %>
            </div>
          </div>
          <div class="av-card-overlay"></div>
          <div class="av-card-content">
            <p class="av-card-tag">Audiovisual</p>
            <h3 class="av-card-title">Institucionais<br>e Eventos</h3>
            <p class="av-card-desc">O bom e velho horizontal —<br>das apresentações à TV.</p>
            <span class="av-cta"><span class="av-play"></span>Clique e assista</span>
          </div>
        </a>

      </div>
    </div>

    <!-- 4e. FOTOGRAFIA -->
    <div class="port-section reveal">
      <div class="port-heading">
        <div><div class="port-tag">Portfólio</div><h3>Fotografia</h3></div>
        <div class="port-desc">Captação profissional em 4k — alimentação,<br>produto e institucional.</div>
      </div>

      <div class="filter-bar" id="photo-filter-bar">
        <button class="filter-btn active" data-pcat="all">Todos</button>
        <% if(assets.fotografiaAlimentacao.length){%><button class="filter-btn" data-pcat="alimentacao">Alimentação</button><%}%>
        <% if(assets.fotografiaInstitucional.length){%><button class="filter-btn" data-pcat="institucional">Institucional</button><%}%>
        <% if(assets.fotografiaProduto.length){%><button class="filter-btn" data-pcat="produto">Produto</button><%}%>
      </div>

      <%
        // Divide um array em N fatias por índice mod N — cada imagem aparece em APENAS UMA linha
        function splitRows(arr, n) {
          const rows = Array.from({length: n}, () => []);
          arr.forEach((img, i) => rows[i % n].push(img));
          return rows;
        }
        // Pool "todos" — intercala categorias antes de dividir, para cada linha ter mix variado
        const _poolAll = [];
        const _a = assets.fotografiaAlimentacao;
        const _b = assets.fotografiaInstitucional;
        const _c = assets.fotografiaProduto;
        const _maxAll = Math.max(_a.length, _b.length, _c.length);
        for (let i = 0; i < _maxAll; i++) {
          if (i < _a.length) _poolAll.push(_a[i]);
          if (i < _b.length) _poolAll.push(_b[i]);
          if (i < _c.length) _poolAll.push(_c[i]);
        }
        const _allRows = splitRows(_poolAll, 3);
      %>

      <div id="pgallery-all">
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track" style="--spd:187s;">
            <% [..._allRows[0],..._allRows[0]].forEach((img,i)=>{ %>
              <img src="<%= img %>" alt="" loading="<%= i<6?'eager':'lazy' %>" data-fotosrc="<%= img %>">
            <% }) %>
          </div>
        </div>
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track" style="--spd:210s;">
            <% [..._allRows[2],..._allRows[2]].forEach((img,i)=>{ %>
              <img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>">
            <% }) %>
          </div>
        </div>
        <div class="ticker-wrap">
          <div class="ticker-track rev" style="--spd:152s;">
            <% [..._allRows[1],..._allRows[1]].forEach((img,i)=>{ %>
              <img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>">
            <% }) %>
          </div>
        </div>
      </div>

      <div id="pgallery-alimentacao" style="display:none;">
        <% const _alRows = splitRows(assets.fotografiaAlimentacao, 3); %>
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track" style="--spd:105s;">
            <% [..._alRows[0],..._alRows[0]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track" style="--spd:88s;">
            <% [..._alRows[2],..._alRows[2]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
        <div class="ticker-wrap">
          <div class="ticker-track rev" style="--spd:128s;">
            <% [..._alRows[1],..._alRows[1]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
      </div>

      <div id="pgallery-institucional" style="display:none;">
        <% const _insRows = splitRows(assets.fotografiaInstitucional, 3); %>
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track rev" style="--spd:128s;">
            <% [..._insRows[0],..._insRows[0]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track rev" style="--spd:111s;">
            <% [..._insRows[2],..._insRows[2]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
        <div class="ticker-wrap">
          <div class="ticker-track" style="--spd:152s;">
            <% [..._insRows[1],..._insRows[1]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
      </div>

      <div id="pgallery-produto" style="display:none;">
        <% const _prRows = splitRows(assets.fotografiaProduto, 3); %>
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track" style="--spd:117s;">
            <% [..._prRows[0],..._prRows[0]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
        <div class="ticker-wrap" style="margin-bottom:6px;">
          <div class="ticker-track" style="--spd:140s;">
            <% [..._prRows[2],..._prRows[2]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
        <div class="ticker-wrap">
          <div class="ticker-track rev" style="--spd:99s;">
            <% [..._prRows[1],..._prRows[1]].forEach(img=>{ %><img src="<%= img %>" alt="" loading="lazy" data-fotosrc="<%= img %>"><% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- 4f. PACKAGING -->
    <% if (assets.packaging.length) { %>
    <div class="port-section reveal">
      <div class="port-heading">
        <div><div class="port-tag">Portfólio</div><h3>Packaging</h3></div>
        <div class="port-desc">Design de embalagem que seduz na prateleira<br>e reforça a identidade da marca.</div>
      </div>
      <div class="pkg-bento-wrap pkg-collapsed" id="pkg-wrap">
        <div class="pkg-bento">
          <%
            const pkgReordered = [...assets.packaging];
            const img4 = pkgReordered.splice(3, 1)[0];
            const img12 = pkgReordered.splice(10, 1)[0];
            pkgReordered.splice(3, 0, img12);
            pkgReordered.push(img4);
          %>
          <% pkgReordered.forEach((img,i)=>{ %>
            <div class="pkg-bento-card <%= i%3===0?'tall':'' %>"
                 data-pkgsrc="<%= img %>" data-pkgidx="<%= assets.packaging.indexOf(img) %>">
              <img src="<%= img %>" alt="" loading="lazy">
              <div class="pkg-bento-overlay"></div>
            </div>
          <% }) %>
        </div>
      </div>
      <div style="text-align:center;" id="pkg-ver-mais-wrap">
        <button class="ver-mais-btn" id="pkg-ver-mais-btn">Ver mais ↓</button>
      </div>
    </div>
    <% } %>

  </div>
</section>

<!-- ════════════════════════════════════════════════
     5. CLIENTES
════════════════════════════════════════════════ -->
<% if (assets.logosClientes.length) { %>
<section class="section clients-section">
  <div class="container">
    <div style="margin-bottom:3rem;">
      <div class="sec-num reveal" style="float:left;margin-right:1.5rem;line-height:.85;">05</div>
      <p class="label reveal" style="margin-bottom:.4rem;">Confiança</p>
      <h2 class="reveal" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;margin:0 0 .5rem;line-height:1.1;clear:both;color:#111;">Clientes</h2>
      <p class="reveal" style="color:#666;font-size:.95rem;margin:0;max-width:560px;">
        Marcas que confiam na HUP para uma solução 360° — da estratégia digital à produção criativa.
      </p>
    </div>
    <div class="logo-grid reveal">
      <%
        const _lastKeys = ['flat cambuci','cmsa','gustavo sisant'];
        const _sorted = assets.logosClientes.slice().sort((a,b)=>{
          const aL=_lastKeys.some(k=>a.toLowerCase().includes(k));
          const bL=_lastKeys.some(k=>b.toLowerCase().includes(k));
          return aL===bL?0:aL?1:-1;
        });
      %>
      <% _sorted.forEach((logo,i)=>{ %>
        <div class="logo-item"><img src="<%= logo %>" alt="Cliente <%= i+1 %>" loading="lazy"></div>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<!-- ════════════════════════════════════════════════
     6. PROPOSTA — Branding (itens + investimento)
════════════════════════════════════════════════ -->
<section class="section" style="border-top:1px solid #111;">
  <div class="container">
    <div style="margin-bottom:3rem;">
      <div class="sec-num reveal" style="float:left;margin-right:1.5rem;line-height:.85;">06</div>
      <p class="label reveal" style="margin-bottom:.5rem;">Proposta para <%= proposal.client.company %></p>
      <h2 class="reveal" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;margin:0;line-height:1.1;clear:both;"><%= proposal.proposalTitle %></h2>
    </div>

    <div class="proposal-intro reveal">
      <p style="font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--cyan);margin:0 0 .5rem;">Sobre este projeto</p>
      <p style="color:#888;font-size:.95rem;line-height:1.8;margin:0;max-width:720px;">
        <%= proposal.proposalIntro %>
      </p>
    </div>

    <div class="branding-items" id="branding-grid">
      <% proposal.items.forEach((item, idx) => { %>
        <div class="branding-card" data-item-idx="<%= idx %>">
          <div class="branding-card-header">
            <div style="flex:1;">
              <p class="branding-card-subtitle"><%= item.subtitle %></p>
              <h3 class="branding-card-name"><%= item.name %></h3>
            </div>
            <div style="text-align:right;flex-shrink:0;">
              <div class="branding-card-id"><%= item.id %></div>
              <div class="branding-card-price<%= item.gift ? ' strikethrough' : '' %>"><%= item.price %></div>
              <% if (item.gift) { %>
                <div style="display:flex;justify-content:flex-end;margin-top:.4rem;">
                  <span class="branding-gift-badge">🎁 brinde</span>
                </div>
              <% } %>
            </div>
          </div>
          <div style="border-top:1px solid #1e1e1e;padding-top:1.25rem;">
            <% item.deliverables.forEach(d => { %>
              <div class="check-item"><span class="check-icon">✓</span><span style="color:#bbb;font-size:.88rem;"><%= d %></span></div>
            <% }) %>
            <% if (item.note) { %>
              <p class="branding-card-note">* <%= item.note %></p>
            <% } %>
            <% if (item.obs) { %>
              <p class="branding-card-obs">* <%= item.obs %></p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Investimento total -->
    <% if (proposal.investment) { %>
    <div class="investment-block reveal">
      <div class="invest-item">
        <p class="invest-label">Investimento total</p>
        <div class="invest-value"><%= proposal.investment.total %></div>
        <p class="invest-sub">Valor completo do projeto</p>
      </div>
      <div class="invest-divider"></div>
      <div class="invest-item">
        <p class="invest-label">À vista com desconto</p>
        <div class="invest-value" style="color:var(--cyan);"><%= proposal.investment.cashDiscount %></div>
        <p class="invest-sub">Pagamento único</p>
      </div>
      <div class="invest-divider"></div>
      <div class="invest-item">
        <p class="invest-label">Parcelado em até <%= proposal.investment.installments.count %>x</p>
        <div class="invest-value" style="font-size:clamp(1.2rem,2.5vw,1.7rem);">
          <%= proposal.investment.installments.count %>x de <%= proposal.investment.installments.value %>
        </div>
        <p class="invest-sub">Via <%= proposal.investment.installments.method %></p>
      </div>
    </div>
    <% } %>

    <div style="text-align:center;margin-top:3rem;">
      <a href="<%= proposal.cta.meetingLink %>" target="_blank"
         class="cta-btn-pulse"
         style="display:inline-block;background:var(--blue);color:#fff;font-family:inherit;font-size:.85rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:.85rem 2.2rem;border-radius:3px;transition:filter 200ms;">
        Quero avançar com esse projeto ↗
      </a>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════
     7. CTA FINAL
════════════════════════════════════════════════ -->
<section class="section" style="border-top:1px solid #111;text-align:center;">
  <div class="container" style="max-width:600px;">
    <p class="label reveal" style="margin-bottom:1rem;">Próximo passo</p>
    <h2 class="reveal" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;margin:0 0 2.5rem;line-height:1.1;">
      Vamos<br><span style="color:var(--cyan);">Conversar?</span>
    </h2>
    <div class="reveal" style="margin-bottom:2rem;">
      <a href="<%= proposal.cta.meetingLink %>" target="_blank" class="cta-btn">Agendar reunião ↗</a>
    </div>
    <div class="reveal" style="color:#444;font-size:.85rem;line-height:2.2;">
      <% if(proposal.cta.whatsapp){%>
        <div>WhatsApp: <a href="https://wa.me/<%= proposal.cta.whatsapp.replace(/\D/g,'') %>" style="color:#666;text-decoration:none;" target="_blank"><%= proposal.cta.whatsapp %></a></div>
      <%}%>
      <% if(proposal.cta.email){%>
        <div>E-mail: <a href="mailto:<%= proposal.cta.email %>" style="color:#666;text-decoration:none;"><%= proposal.cta.email %></a></div>
      <%}%>
    </div>
  </div>
</section>

<footer style="border-top:1px solid #111;padding:2rem;text-align:center;color:#222;font-size:.72rem;letter-spacing:.06em;">
  © <%= new Date().getFullYear() %> HUP Creative — hupcreative.cloud
</footer>

<!-- ════════════════════════════════════════════════
     JS
════════════════════════════════════════════════ -->
<script>
  const GALLERIES = {
    redesSociais: <%- JSON.stringify(assets.redesSociais) %>,
    ecommerce:    <%- JSON.stringify(assets.ecommerce) %>,
    offline:      <%- JSON.stringify(assets.offline) %>,
    packaging:    <%- JSON.stringify(assets.packaging) %>,
  };
  const FOTO_ALL = [
    ...<%- JSON.stringify(assets.fotografiaAlimentacao) %>,
    ...<%- JSON.stringify(assets.fotografiaInstitucional) %>,
    ...<%- JSON.stringify(assets.fotografiaProduto) %>,
  ];
  const FOTO_CATS = {
    alimentacao: <%- JSON.stringify(assets.fotografiaAlimentacao) %>,
    institucional: <%- JSON.stringify(assets.fotografiaInstitucional) %>,
    produto: <%- JSON.stringify(assets.fotografiaProduto) %>,
  };

  // ── Scroll reveal ──────────────────────────────
  const revObs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');revObs.unobserve(e.target);}});
  },{threshold:0.06});
  document.querySelectorAll('.reveal').forEach(el=>revObs.observe(el));

  // ── Hero entrance ──────────────────────────────
  document.querySelectorAll('.hero-item').forEach((el,i)=>{
    setTimeout(()=>el.classList.add('visible'), 150 + i * 200);
  });

  // ── Hero rotating word ─────────────────────────
  (function(){
    const slot = document.getElementById('hero-rotate');
    if(!slot) return;
    const words = slot.querySelectorAll('span');
    if(!words.length) return;
    let cur = 0;
    words[0].classList.add('hw-in');
    setInterval(()=>{
      words[cur].classList.remove('hw-in');
      words[cur].classList.add('hw-out');
      const prev = cur;
      setTimeout(()=> words[prev].classList.remove('hw-out'), 350);
      cur = (cur + 1) % words.length;
      words[cur].classList.add('hw-in');
    }, 2200);
  })();

  // ── Branding cards stagger ─────────────────────
  const brandObs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        setTimeout(()=>e.target.classList.add('visible'), parseInt(e.target.dataset.itemIdx||0)*180);
        brandObs.unobserve(e.target);
      }
    });
  },{threshold:0.08});
  document.querySelectorAll('.branding-card').forEach(el=>brandObs.observe(el));

  // ── Branding grid responsive ───────────────────
  function setBrandingGrid(){
    const g=document.getElementById('branding-grid');if(!g)return;
    const n=g.children.length;
    g.style.gridTemplateColumns=(window.innerWidth>=768&&n>=2)?`repeat(2,1fr)`:'1fr';
  }
  setBrandingGrid();
  window.addEventListener('resize',setBrandingGrid);

  // ── Lightbox ───────────────────────────────────
  const lb=document.getElementById('lightbox');
  const lbImg=document.getElementById('lb-img');
  const lbCount=document.getElementById('lb-count');
  let lbGal=[],lbIdx=0;

  function openLb(gallery,idx){
    lbGal=gallery;lbIdx=idx;
    lbImg.src=lbGal[lbIdx];
    lbCount.textContent=(lbIdx+1)+' / '+lbGal.length;
    lb.classList.add('open');
    document.body.style.overflow='hidden';
  }
  function closeLb(){
    lb.classList.remove('open');
    document.body.style.overflow='';
    setTimeout(()=>{lbImg.src='';},300);
  }
  function lbNav(d){
    lbIdx=(lbIdx+d+lbGal.length)%lbGal.length;
    lbImg.src=lbGal[lbIdx];
    lbCount.textContent=(lbIdx+1)+' / '+lbGal.length;
  }
  document.getElementById('lb-close').onclick=closeLb;
  lb.addEventListener('click',e=>{if(e.target===lb)closeLb();});
  document.getElementById('lb-prev').onclick=()=>lbNav(-1);
  document.getElementById('lb-next').onclick=()=>lbNav(1);
  document.addEventListener('keydown',e=>{
    if(!lb.classList.contains('open'))return;
    if(e.key==='Escape')closeLb();
    if(e.key==='ArrowLeft')lbNav(-1);
    if(e.key==='ArrowRight')lbNav(1);
  });

  // Wire masonry clicks
  document.querySelectorAll('.masonry-item').forEach(item=>{
    item.addEventListener('click',()=>{
      const gKey=item.dataset.gallery;
      const gallery=GALLERIES[gKey];
      if(!gallery)return;
      openLb(gallery,parseInt(item.dataset.index,10)||0);
    });
  });

  // ── Drag-to-scroll (packaging bento) ──────────
  document.querySelectorAll('.pkg-bento-wrap').forEach(wrap=>{
    let down=false,startX=0,scrollLeft=0;
    wrap.addEventListener('mousedown',e=>{
      down=true;wrap.classList.add('grabbing');
      startX=e.pageX-wrap.offsetLeft;scrollLeft=wrap.scrollLeft;
    });
    wrap.addEventListener('mouseleave',()=>{down=false;wrap.classList.remove('grabbing');});
    wrap.addEventListener('mouseup',()=>{down=false;wrap.classList.remove('grabbing');});
    wrap.addEventListener('mousemove',e=>{
      if(!down)return;e.preventDefault();
      wrap.scrollLeft=scrollLeft-(e.pageX-wrap.offsetLeft-startX)*1.5;
    });
  });

  // Wire packaging bento clicks → lightbox
  document.querySelectorAll('.pkg-bento-card').forEach(card=>{
    card.addEventListener('click',()=>{
      const idx=parseInt(card.dataset.pkgidx,10)||0;
      openLb(GALLERIES.packaging,idx);
    });
  });

  // Wire foto scroll clicks → lightbox
  document.querySelectorAll('[data-fotosrc]').forEach(img=>{
    img.addEventListener('click',()=>{
      const src=img.dataset.fotosrc;
      const idx=FOTO_ALL.indexOf(src);
      openLb(FOTO_ALL,idx>=0?idx:0);
    });
  });

  // Wire ecommerce clicks → lightbox
  document.querySelectorAll('[data-gallery="ecommerce"]').forEach(img=>{
    img.addEventListener('click',()=>{
      const idx=parseInt(img.dataset.index,10)||0;
      openLb(GALLERIES.ecommerce,idx);
    });
  });

  // ── Photo filter → switch gallery group ────────
  document.querySelectorAll('#photo-filter-bar .filter-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      document.querySelectorAll('#photo-filter-bar .filter-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      const cat=btn.dataset.pcat;
      ['all','alimentacao','institucional','produto'].forEach(c=>{
        const el=document.getElementById('pgallery-'+c);
        if(el) el.style.display=(cat===c)?'':'none';
      });
    });
  });

  // ── Ver mais ───────────────────────────────────
  document.querySelectorAll('.ver-mais-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      const target=document.getElementById(btn.dataset.target);
      if(!target)return;
      target.classList.add('expanded');
      btn.classList.add('hidden');
    });
  });

  // ── Ver mais packaging (mobile only) ──────────
  const pkgBtn = document.getElementById('pkg-ver-mais-btn');
  const pkgWrap = document.getElementById('pkg-wrap');
  if(pkgBtn && pkgWrap){
    // só mostra o botão em mobile
    function syncPkgBtn(){
      const isMobile = window.innerWidth <= 768;
      document.getElementById('pkg-ver-mais-wrap').style.display = isMobile ? '' : 'none';
      if(!isMobile) pkgWrap.classList.remove('pkg-collapsed');
      else pkgWrap.classList.add('pkg-collapsed');
    }
    syncPkgBtn();
    window.addEventListener('resize', syncPkgBtn);
    pkgBtn.addEventListener('click',()=>{
      pkgWrap.classList.remove('pkg-collapsed');
      document.getElementById('pkg-ver-mais-wrap').style.display='none';
    });
  }
</script>
</body>
</html>
