<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proposta HUP Creative — <%= proposal.client.company %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Poppins:ital,wght@0,700;0,800;1,700;1,800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{hup:'#1400FF',cyan:'#00CFFF',surface:'#111111'},fontFamily:{sans:['Space Grotesk','sans-serif']}}}}</script>

  <style>
    :root{--blue:#1400FF;--cyan:#00CFFF;--bg:#0a0a0a;--surface:#111111;}
    *{box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:#fff;font-family:'Space Grotesk',sans-serif;margin:0;overflow-x:hidden;}

    /* ── Grain ── */
    .grain::before{
      content:'';position:fixed;inset:0;pointer-events:none;z-index:998;opacity:.04;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size:200px 200px;
    }

    /* ── Layout ── */
    .section{padding:6rem 0;}
    @media(max-width:768px){.section{padding:4rem 0;}}
    .container{max-width:1200px;margin:0 auto;padding:0 2rem;}

    /* ── Reveals ── */
    .reveal{opacity:0;transform:translateY(30px);transition:opacity 500ms ease-out,transform 500ms ease-out;}
    .reveal.visible{opacity:1;transform:translateY(0);}

    /* ── Hero ── */
    .hero-item{opacity:0;transform:translateY(24px);transition:opacity 600ms ease-out,transform 600ms ease-out;}
    .hero-item.visible{opacity:1;transform:translateY(0);}

    /* ── Hero novo ── */
    .hero-badge-pill{display:inline-flex;align-items:center;gap:.55rem;padding:.38rem 1rem;border:1px solid #222;border-radius:999px;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:#666;margin-bottom:2rem;backdrop-filter:blur(8px);}
    .hero-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--cyan);flex-shrink:0;animation:dot-pulse 2s ease-in-out infinite;}
    @keyframes dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.65)}}

    .hero-main-title{font-family:'Poppins',sans-serif;font-size:clamp(3rem,7.5vw,6.5rem);font-weight:800;line-height:1.08;text-align:center;margin:0 0 1.5rem;width:100%;color:#fff;}
    .hero-title-sub{display:block;font-family:'Poppins',sans-serif;font-size:clamp(1.4rem,3.2vw,2.4rem);font-weight:700;color:#fff;letter-spacing:-.01em;}
    /* Slot para palavra rotativa */
    .hero-rotate-slot{display:block;position:relative;height:1.22em;overflow:hidden;margin:.12em 0;width:100%;}
    .hero-rotate-slot span{
      position:absolute;left:0;right:0;
      text-align:center;
      font-family:'Poppins',sans-serif;
      font-size:clamp(3rem,7.5vw,6.5rem);
      font-weight:800;font-style:italic;
      white-space:nowrap;overflow:hidden;
      background:linear-gradient(90deg,var(--blue),var(--cyan));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      opacity:0;transform:translateY(110%);
      transition:opacity .45s cubic-bezier(.16,1,.3,1),transform .45s cubic-bezier(.16,1,.3,1);
    }
    .hero-rotate-slot span.hw-in{opacity:1;transform:translateY(0);}
    .hero-rotate-slot span.hw-out{opacity:0;transform:translateY(-110%);transition:opacity .3s ease,transform .3s ease;}

    .hero-subtitle{font-size:clamp(.9rem,1.8vw,1.1rem);color:#666;line-height:1.75;margin:0 0 2.5rem;text-align:center;}
    .hero-subtitle strong{color:#bbb;font-weight:500;}

    .hero-scroll-btn{display:inline-flex;align-items:center;gap:.55rem;padding:.6rem 1.4rem;border:1px solid #252525;border-radius:999px;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:#484848;background:transparent;cursor:pointer;font-family:inherit;transition:border-color 300ms,color 300ms,transform 300ms;}
    .hero-scroll-btn:hover{border-color:#555;color:#aaa;transform:translateY(2px);}
    .hero-scroll-arrow{animation:arrow-bounce 1.8s ease-in-out infinite;}
    @keyframes arrow-bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(4px)}}

    /* Hero — pontos hexagonais com luz orbital nas bordas */
    .hero-bg{position:absolute;inset:0;overflow:hidden;z-index:0;}
    .hero-dots{
      position:absolute;inset:0;
      background-color:#0a0a0a;
      background-image:
        radial-gradient(circle at 50% 50%, transparent 1.5px, #0a0a0a 0 8px, transparent 8px),
        radial-gradient(circle at 50% 50%, transparent 1.5px, #0a0a0a 0 8px, transparent 8px),
        radial-gradient(ellipse at center, #0a0a0a 18%, transparent 62%),
        radial-gradient(ellipse at 0% 0%, rgba(20,0,255,.92), transparent 52%),
        radial-gradient(ellipse at 100% 100%, rgba(20,0,255,.75), transparent 52%);
      background-size:
        10px 17.32px,
        10px 17.32px,
        100% 100%,
        210% 210%,
        210% 210%;
      background-position: 0 0, 5px 8.66px, center, 0% 0%, 100% 100%;
      animation: edge-orbit 14s linear infinite;
    }
    @keyframes edge-orbit{
      0%  {background-position:0 0,5px 8.66px,center,  0%   0%,  100% 100%;}
      25% {background-position:0 0,5px 8.66px,center,100%   0%,    0% 100%;}
      50% {background-position:0 0,5px 8.66px,center,100% 100%,    0%   0%;}
      75% {background-position:0 0,5px 8.66px,center,  0% 100%,  100%   0%;}
      100%{background-position:0 0,5px 8.66px,center,  0%   0%,  100% 100%;}
    }

    /* Hero geo accent */
    .hero-geo{
      position:absolute;right:8%;top:50%;transform:translateY(-50%);
      width:320px;height:320px;opacity:.07;
      animation:geo-spin 30s linear infinite;
    }
    @keyframes geo-spin{from{transform:translateY(-50%) rotate(0deg);}to{transform:translateY(-50%) rotate(360deg);}}

    .hero-line{
      position:absolute;left:0;right:0;bottom:0;height:1px;
      background:linear-gradient(to right,transparent,#1400FF 30%,#00CFFF 70%,transparent);
      opacity:.4;
    }

    /* ── Sec number ── */
    .sec-num{font-size:clamp(5rem,15vw,10rem);font-weight:700;color:#1a1a1a;line-height:1;user-select:none;}

    /* ── Services ── */
    @keyframes svc-pulse{
      0%,100%{border-color:#222;background:transparent;box-shadow:none;}
      50%{border-color:var(--blue);background:rgba(20,0,255,.07);box-shadow:inset 0 0 24px rgba(20,0,255,.08),0 0 12px rgba(20,0,255,.08);}
    }
    .service-item{
      border:1px solid #222;padding:1.5rem;cursor:default;
      clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));
      animation:svc-pulse 5s ease-in-out infinite;
      transition:background 200ms,color 200ms,border-color 200ms;
    }
    .service-item:nth-child(1){animation-delay:0s;}
    .service-item:nth-child(2){animation-delay:.6s;}
    .service-item:nth-child(3){animation-delay:1.2s;}
    .service-item:nth-child(4){animation-delay:1.8s;}
    .service-item:nth-child(5){animation-delay:2.4s;}
    .service-item:nth-child(6){animation-delay:3s;}
    .service-item:nth-child(7){animation-delay:3.6s;}
    .service-item:nth-child(8){animation-delay:4.2s;}
    .service-item:hover{background:var(--blue);border-color:var(--blue);animation:none;}
    .service-item:hover .service-arrow{color:#fff;}

    /* ── Holo logo ── */
    .holo-logo{
      animation:holo-float 6s ease-in-out infinite;
      filter:drop-shadow(0 0 30px rgba(0,207,255,.4));
    }
    @keyframes holo-float{
      0%,100%{transform:translateY(0) rotate(-2deg);}
      50%{transform:translateY(-20px) rotate(2deg);}
    }
    @media(max-width:768px){
      .holo-logo{display:none!important;}
      .about-grid{grid-template-columns:1fr!important;gap:2rem!important;}
      .services-grid{grid-template-columns:repeat(2,1fr)!important;}
    }

    /* ── Portfolio heading ── */
    .port-section{margin-bottom:5rem;}
    .port-heading{display:flex;align-items:flex-end;gap:1.5rem;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:1px solid #1a1a1a;}
    .port-heading h3{font-size:clamp(1.5rem,3vw,2.2rem);font-weight:700;text-transform:uppercase;letter-spacing:.03em;margin:0;line-height:1;}
    .port-desc{font-size:.8rem;color:#888;letter-spacing:.04em;line-height:1.5;padding-bottom:2px;}
    .port-tag{font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;color:var(--cyan);margin-bottom:.3rem;}

    /* ── Masonry ── */
    .masonry{columns:4;column-gap:6px;}
    .masonry.cols-3{columns:3;}
    @media(max-width:900px){.masonry{columns:2!important;}}
    @media(max-width:500px){.masonry{columns:2!important;}}

    .masonry-item{break-inside:avoid;margin-bottom:6px;overflow:hidden;cursor:pointer;}
    .masonry-item img{width:100%;height:auto;display:block;transition:transform 400ms ease,filter 300ms;}
    .masonry-item:hover img{transform:scale(1.05);filter:brightness(1.1);}
    /* E-commerce grid */
    .eco-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px;}
    .eco-grid-item{overflow:hidden;border-radius:6px;cursor:zoom-in;aspect-ratio:1/1;transition:box-shadow 200ms;}
    .eco-grid-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 300ms;}
    .eco-grid-item:hover img{transform:scale(1.05);}
    .eco-grid-item:hover{box-shadow:0 6px 20px rgba(0,0,0,.5);}
    .eco-grid-item.span-2{grid-column:span 2;aspect-ratio:2/1;}
    .eco-grid-item.span-3{grid-column:span 3;aspect-ratio:3/1;}
    .eco-grid-item.span-4{grid-column:span 4;aspect-ratio:4/1;}
    @media(max-width:768px){
      .eco-grid{grid-template-columns:repeat(2,1fr);}
      .eco-grid-item.span-2,.eco-grid-item.span-3,.eco-grid-item.span-4{grid-column:span 2;aspect-ratio:2/1;}
    }

    /* ── Collapse / ver mais ── */
    .collapsible-grid{position:relative;max-height:520px;overflow:hidden;transition:max-height 700ms ease;}
    .collapsible-grid.expanded{max-height:9000px;}
    .collapsible-grid::after{
      content:'';position:absolute;bottom:0;left:0;right:0;height:200px;
      background:linear-gradient(to top,var(--bg) 0%,transparent 100%);
      pointer-events:none;transition:opacity 400ms;
    }
    .collapsible-grid.expanded::after{opacity:0;pointer-events:none;}

    .ver-mais-btn{
      display:flex;align-items:center;gap:.6rem;
      margin:1.5rem auto 0;
      padding:.7rem 1.8rem;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.1);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      color:#fff;font-family:inherit;font-size:.78rem;font-weight:600;
      letter-spacing:.1em;text-transform:uppercase;cursor:pointer;
      border-radius:4px;
      transition:background 200ms,border-color 200ms,transform 200ms;
      position:relative;z-index:2;
    }
    .ver-mais-btn:hover{background:rgba(20,0,255,.25);border-color:rgba(20,0,255,.5);transform:scale(1.02);}
    .ver-mais-btn.hidden{display:none;}

    /* ── Audiovisual cards ── */
    .av-cards{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
    @media(max-width:640px){.av-cards{grid-template-columns:1fr;}}

    .av-card{
      position:relative;overflow:hidden;min-height:360px;
      cursor:pointer;text-decoration:none;display:block;
    }
    .av-card-bg{
      position:absolute;inset:0;
      display:flex;gap:4px;
      filter:blur(14px) brightness(.2) saturate(.5);
      transform:scale(1.12);
    }
    .av-card-bg-col{display:flex;flex-direction:column;gap:4px;flex:0 0 auto;width:33.33%;}
    .av-card-bg-col img{width:100%;flex:1;object-fit:cover;display:block;}

    .av-card-bg-col:nth-child(1){animation:av-slide-up 18s linear infinite;}
    .av-card-bg-col:nth-child(2){animation:av-slide-down 22s linear infinite;}
    .av-card-bg-col:nth-child(3){animation:av-slide-up 15s linear infinite;}

    @keyframes av-slide-up{0%{transform:translateY(0);}100%{transform:translateY(-33%);}}
    @keyframes av-slide-down{0%{transform:translateY(-33%);}100%{transform:translateY(0);}}

    .av-card:hover .av-card-bg{filter:blur(10px) brightness(.3) saturate(.7);}
    .av-card-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(20,0,255,.2) 0%,transparent 60%);}
    .av-card-content{position:relative;z-index:2;padding:2.5rem;height:100%;display:flex;flex-direction:column;justify-content:flex-end;}
    .av-card-tag{font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--cyan);margin-bottom:.75rem;}
    .av-card-title{font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;text-transform:uppercase;line-height:1;margin:0 0 .75rem;color:#fff;}
    .av-card-desc{font-size:.85rem;color:#aaa;margin:0 0 2rem;line-height:1.5;}
    .av-cta{
      display:inline-flex;align-items:center;gap:.6rem;
      background:var(--blue);color:#fff;font-family:inherit;font-size:.78rem;font-weight:700;
      letter-spacing:.1em;text-transform:uppercase;padding:.7rem 1.4rem;border-radius:3px;
      align-self:flex-start;transition:filter 200ms,transform 200ms;
    }
    .av-cta:hover{filter:brightness(1.2);transform:scale(1.03);}
    .av-play{width:0;height:0;border-top:5px solid transparent;border-bottom:5px solid transparent;border-left:9px solid #fff;display:inline-block;}

    /* ── Ticker ── */
    .ticker-wrap{overflow:hidden;mask-image:linear-gradient(to right,transparent,black 2%,black 98%,transparent);}
    .ticker-track{display:inline-flex;gap:6px;animation:ticker-scroll var(--spd,55s) linear infinite;will-change:transform;}
    .ticker-track.rev{animation-direction:reverse;}
    @keyframes ticker-scroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
    .ticker-wrap:hover .ticker-track{animation-play-state:paused;}
    .ticker-track img{height:180px;width:auto;min-width:120px;object-fit:cover;flex-shrink:0;display:block;border:2px solid transparent;transition:filter 200ms,border-color 200ms;cursor:zoom-in;}
    .ticker-track img:hover{filter:brightness(1.1);border-color:var(--blue);}
    @media(max-width:768px){.ticker-track img{height:130px;min-width:90px;}}

    /* Photo filter buttons */
    .filter-bar{display:flex;gap:.5rem;flex-wrap:wrap;margin-bottom:1rem;}
    .filter-btn{
      padding:.35rem .9rem;border:1px solid #333;background:none;color:#666;
      font-family:inherit;font-size:.75rem;letter-spacing:.08em;text-transform:uppercase;
      cursor:pointer;transition:all 200ms;
    }
    .filter-btn:hover{border-color:#666;color:#fff;}
    .filter-btn.active{background:var(--blue);border-color:var(--blue);color:#fff;}

    /* ── Packaging bento ── */
    .pkg-bento-wrap{
      overflow-x:auto;cursor:grab;-webkit-overflow-scrolling:touch;
      scrollbar-width:thin;scrollbar-color:#2a2a2a transparent;
      mask-image:linear-gradient(to right,transparent,black 2%,black 98%,transparent);
      padding-bottom:8px;
    }
    .pkg-bento-wrap::-webkit-scrollbar{height:4px;}
    .pkg-bento-wrap::-webkit-scrollbar-thumb{background:#2a2a2a;border-radius:2px;}
    .pkg-bento-wrap.grabbing{cursor:grabbing;user-select:none;}
    .pkg-bento{
      display:grid;
      grid-auto-flow:column;
      grid-auto-columns:minmax(220px,1fr);
      grid-template-rows:repeat(2,240px);
      gap:8px;width:max-content;min-width:100%;
    }
    .pkg-bento-card{
      position:relative;overflow:hidden;border-radius:10px;cursor:zoom-in;
      transition:box-shadow 300ms;
    }
    .pkg-bento-card.tall{grid-row:span 2;}
    .pkg-bento-card img{width:100%;height:100%;object-fit:cover;display:block;transition:transform 500ms ease;}
    .pkg-bento-card:hover img{transform:scale(1.06);}
    .pkg-bento-overlay{
      position:absolute;inset:0;
      background:linear-gradient(to top,rgba(0,0,0,.65) 0%,rgba(0,0,0,.1) 50%,transparent 100%);
      opacity:0;transition:opacity 400ms;
    }
    .pkg-bento-card:hover .pkg-bento-overlay{opacity:1;}
    .pkg-bento-card:hover{box-shadow:0 16px 40px rgba(0,0,0,.5);}

    @media(max-width:768px){
      .pkg-bento-wrap{overflow-x:visible;mask-image:none;cursor:default;padding-bottom:0;}
      .pkg-bento-wrap.pkg-collapsed{max-height:520px;overflow:hidden;position:relative;}
      .pkg-bento-wrap.pkg-collapsed::after{
        content:'';position:absolute;bottom:0;left:0;right:0;height:180px;
        background:linear-gradient(to top,var(--bg) 0%,transparent 100%);
        pointer-events:none;
      }
      .pkg-bento{
        display:grid;
        grid-template-columns:repeat(2,1fr);
        grid-template-rows:none;
        grid-auto-flow:row;
        grid-auto-columns:unset;
        width:100%;min-width:unset;
        gap:6px;
      }
      .pkg-bento-card{aspect-ratio:1/1;border-radius:6px;}
      .pkg-bento-card.tall{grid-row:span 1;}
    }

    /* ── Logo wall ── */
    .clients-section{background:#f0f0f0;}
    .clients-section .sec-num{color:#ddd;}
    .clients-section h2,.clients-section .label,.clients-section p{color:#111!important;}
    .clients-section .label{color:var(--blue)!important;}

    .logo-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:2rem;align-items:center;justify-items:center;}
    @media(max-width:768px){.logo-grid{grid-template-columns:repeat(3,1fr);}}
    @media(max-width:480px){.logo-grid{grid-template-columns:repeat(2,1fr);}}
    .logo-item{display:flex;align-items:center;justify-content:center;padding:.75rem;}
    .logo-item img{max-height:64px;max-width:140px;width:auto;height:auto;object-fit:contain;transition:transform 200ms;}
    .logo-item:hover img{transform:scale(1.1);}

    /* ── Branding items ── */
    .branding-items{display:grid;gap:1.5rem;}
    .branding-card{
      background:var(--surface);border-left:3px solid var(--blue);padding:2.5rem;position:relative;
      opacity:0;transform:translateY(50px) scale(.97);
      transition:opacity 600ms ease-out,transform 600ms ease-out,box-shadow 300ms;
    }
    .branding-card.visible{opacity:1;transform:translateY(0) scale(1);}
    .branding-card-header{display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;margin-bottom:1.5rem;}
    .branding-card-id{font-size:3rem;color:rgba(20,0,255,.06);font-weight:700;line-height:1;user-select:none;flex-shrink:0;}
    .branding-card-name{font-size:clamp(1rem,2vw,1.25rem);font-weight:700;text-transform:uppercase;letter-spacing:.03em;margin:0 0 .3rem;line-height:1.2;}
    .branding-card-subtitle{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:#555;margin:0;}
    .branding-card-price{font-size:clamp(2rem,4vw,2.8rem);font-weight:700;line-height:1;color:#fff;white-space:nowrap;}
    .branding-card-price.strikethrough{text-decoration:line-through;color:#444;font-size:clamp(1.2rem,2.5vw,1.8rem);}
    .branding-card-price:not(.strikethrough){
      background:linear-gradient(90deg,#fff 0%,var(--cyan) 50%,#fff 100%);
      background-size:200% auto;
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
      animation:price-shine 3s linear infinite;
    }
    @keyframes price-shine{0%{background-position:200% center;}100%{background-position:-200% center;}}
    .branding-gift-badge{display:inline-flex;align-items:center;gap:.4rem;margin-top:.4rem;padding:.25rem .75rem;background:rgba(0,207,255,.12);border:1px solid rgba(0,207,255,.3);border-radius:999px;font-size:.65rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--cyan);animation:gift-blink 1.4s ease-in-out infinite;}
    @keyframes gift-blink{0%,100%{opacity:1;box-shadow:0 0 8px rgba(0,207,255,.4);}50%{opacity:.35;box-shadow:none;}}
    .branding-card-note{font-size:.78rem;color:var(--cyan);margin:.75rem 0 0;font-style:italic;}
    .branding-card-obs{font-size:.75rem;color:#555;margin:.4rem 0 0;font-style:italic;}
    .check-item{display:flex;align-items:flex-start;gap:.5rem;margin-bottom:.45rem;}
    .check-icon{color:var(--blue);flex-shrink:0;margin-top:2px;}
    .proposal-intro{margin-bottom:3.5rem;padding:2rem 2.5rem;border-left:3px solid var(--blue);background:#0d0d0d;}

    /* ── Investment summary ── */
    .investment-block{
      margin-top:3rem;padding:2.5rem;
      background:var(--surface);
      border:1px solid #1e1e1e;
      display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem;
      align-items:center;
    }
    @media(max-width:768px){.investment-block{grid-template-columns:1fr;}}
    .invest-item{text-align:center;}
    .invest-label{font-size:.65rem;letter-spacing:.16em;text-transform:uppercase;color:#555;margin:0 0 .5rem;}
    .invest-value{font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;line-height:1;}
    .invest-sub{font-size:.75rem;color:#666;margin:.3rem 0 0;}
    .invest-divider{width:1px;height:100%;background:#1e1e1e;margin:0 auto;}
    @media(max-width:768px){.invest-divider{display:none;}}

    /* ── CTA ── */
    .cta-btn{display:inline-block;background:var(--blue);color:#fff;font-family:inherit;font-size:1rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;text-decoration:none;padding:1rem 2.5rem;border-radius:4px;transition:filter 200ms,transform 200ms;}
    .cta-btn:hover{filter:brightness(1.2);transform:scale(1.02);}
    .cta-btn-pulse{animation:cta-pulse 1.6s ease-in-out infinite;}
    @keyframes cta-pulse{0%,100%{box-shadow:0 0 0 0 rgba(20,0,255,.6),0 0 20px rgba(20,0,255,.3);}50%{box-shadow:0 0 0 10px rgba(20,0,255,0),0 0 30px rgba(20,0,255,.15);}}

    /* ── Lightbox ── */
    #lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.95);z-index:1000;align-items:center;justify-content:center;}
    #lightbox.open{display:flex;}
    #lightbox img{max-width:90vw;max-height:90vh;object-fit:contain;user-select:none;}
    #lb-close{position:absolute;top:1.5rem;right:1.5rem;color:#fff;font-size:2rem;cursor:pointer;background:none;border:none;opacity:.6;}
    #lb-close:hover{opacity:1;}
    #lb-prev,#lb-next{position:absolute;top:50%;transform:translateY(-50%);color:#fff;font-size:2.5rem;cursor:pointer;background:none;border:none;opacity:.4;padding:1rem;}
    #lb-prev:hover,#lb-next:hover{opacity:1;}
    #lb-prev{left:.5rem;}#lb-next{right:.5rem;}
    #lb-count{position:absolute;bottom:1.5rem;left:50%;transform:translateX(-50%);color:#555;font-size:.75rem;letter-spacing:.1em;}

    /* ── label ── */
    .label{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--cyan);font-weight:500;}
  </style>
</head>
<body class="grain">

<!-- Lightbox -->
<div id="lightbox" role="dialog" aria-modal="true">
  <button id="lb-close">✕</button>
  <button id="lb-prev">‹</button>
  <img id="lb-img" src="" alt="">
  <button id="lb-next">›</button>
  <div id="lb-count"></div>
</div>

<!-- ════════════════════════════════════════════════
     1. HERO — Branding
════════════════════════════════════════════════ -->
<section style="min-height:100vh;display:flex;align-items:center;justify-content:center;position:relative;padding:4rem 2rem;overflow:hidden;">

  <!-- Dot grid background -->
  <div class="hero-bg">
    <div class="hero-dots"></div>
  </div>

  <!-- Rotating geometric accent -->
  <svg class="hero-geo" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M100 10 L190 100 L100 190 L10 100 Z" stroke="white" stroke-width="1"/>
    <path d="M100 30 L170 100 L100 170 L30 100 Z" stroke="white" stroke-width="0.5" opacity=".5"/>
    <path d="M100 50 L150 100 L100 150 L50 100 Z" stroke="white" stroke-width="0.5" opacity=".3"/>
    <circle cx="100" cy="100" r="60" stroke="white" stroke-width="0.5" opacity=".2"/>
    <circle cx="100" cy="100" r="80" stroke="white" stroke-width="0.3" opacity=".1"/>
    <line x1="10" y1="100" x2="190" y2="100" stroke="white" stroke-width="0.3" opacity=".2"/>
    <line x1="100" y1="10" x2="100" y2="190" stroke="white" stroke-width="0.3" opacity=".2"/>
  </svg>

  <div class="hero-line"></div>

  <!-- Validade -->
  <div style="position:absolute;top:2rem;right:2rem;color:#444;font-size:.78rem;letter-spacing:.06em;z-index:2;">
    Válida até <span style="color:#666;"><%= proposal.expiresAt %></span>
  </div>

  <div style="text-align:center;max-width:860px;width:100%;position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;">

    <!-- Logo -->
    <div class="hero-item" style="margin-bottom:2rem;">
      <% if (assets.logoHup.length) { %>
        <img src="<%= assets.logoHup.find(l=>l.toLowerCase().includes('branca'))||assets.logoHup[0] %>"
             alt="HUP Creative" style="height:82px;width:auto;display:inline-block;filter:drop-shadow(0 0 28px rgba(20,0,255,.5));">
      <% } %>
    </div>

    <!-- Badge -->
    <div class="hero-item hero-badge-pill">
      <span class="hero-badge-dot"></span>
      01 &nbsp;—&nbsp; Proposta<% if(proposal.serviceType){ %>&nbsp;de&nbsp;<strong style="color:#aaa;font-weight:600;letter-spacing:.06em;"><%= proposal.serviceType %></strong><% } %>
    </div>

    <!-- Título com palavra rotativa -->
    <h1 class="hero-item hero-main-title">
      <span class="hero-title-sub"><%= proposal.client.company %>, uma marca</span>
      <span class="hero-rotate-slot" id="hero-rotate">
        <span>icônica</span>
        <span>memorável</span>
        <span>poderosa</span>
        <span>distinta</span>
        <span>única</span>
      </span>
    </h1>

    <!-- Subtítulo — múltiplos contatos -->
    <%
      const contacts = proposal.client.contacts || [proposal.client.contact];
      let contactStr = '';
      if (contacts.length === 1) {
        contactStr = contacts[0];
      } else {
        contactStr = contacts.slice(0, -1).join(', ') + ' e ' + contacts[contacts.length - 1];
      }
    %>
    <p class="hero-item hero-subtitle">
      <strong><%= contactStr %></strong>, estamos ansiosos<br>para dar vida à Neurobiota.
    </p>

    <!-- Scroll CTA -->
    <button class="hero-item hero-scroll-btn" onclick="window.scrollBy({top:window.innerHeight*.85,behavior:'smooth'})">
      Role para ver
      <svg class="hero-scroll-arrow" width="13" height="13" viewBox="0 0 13 13" fill="none">
        <path d="M6.5 1.5v10M2 8l4.5 4.5L11 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

  </div>
</section>

