<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Proposta HUP Creative — <%= proposal.client.company %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Poppins:ital,wght@0,700;0,800;1,700;1,800&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{hup:'#1400FF',cyan:'#00CFFF',surface:'#111111'},fontFamily:{sans:['Space Grotesk','sans-serif']}}}}</script>

  <style>
    :root{--blue:#1400FF;--cyan:#00CFFF;--bg:#0a0a0a;--surface:#111111;}
    *{box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:#fff;font-family:'Space Grotesk',sans-serif;margin:0;overflow-x:hidden;}

    /* ── Grain ── */
    .grain::before{
      content:'';position:fixed;inset:0;pointer-events:none;z-index:998;opacity:.04;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size:200px 200px;
    }

    /* ── Layout ── */
    .section{padding:6rem 0;}
    @media(max-width:768px){.section{padding:4rem 0;}}
    .container{max-width:1200px;margin:0 auto;padding:0 2rem;}

    /* ── Reveals ── */
    .reveal{opacity:0;transform:translateY(30px);transition:opacity 500ms ease-out,transform 500ms ease-out;}
    .reveal.visible{opacity:1;transform:translateY(0);}

    /* ── Hero ── */
    .hero-item{opacity:0;transform:translateY(20px);transition:opacity 550ms ease-out,transform 550ms ease-out;}
    .hero-item.visible{opacity:1;transform:translateY(0);}

    .hero-badge-pill{display:inline-flex;align-items:center;gap:.55rem;padding:.38rem 1rem;border:1px solid #222;border-radius:999px;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:#666;margin-bottom:2rem;backdrop-filter:blur(8px);}
    .hero-badge-dot{width:6px;height:6px;border-radius:50%;background:var(--cyan);flex-shrink:0;animation:dot-pulse 2s ease-in-out infinite;}
    @keyframes dot-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.35;transform:scale(.65)}}

    /* Hero background — hex dots + orbital edge glow */
    .hero-bg{position:absolute;inset:0;overflow:hidden;z-index:0;}
    .hero-dots{
      position:absolute;inset:0;
      background-color:#0a0a0a;
      background-image:
        radial-gradient(circle at 50% 50%, transparent 1.5px, #0a0a0a 0 8px, transparent 8px),
        radial-gradient(circle at 50% 50%, transparent 1.5px, #0a0a0a 0 8px, transparent 8px),
        radial-gradient(ellipse at center, #0a0a0a 18%, transparent 62%),
        radial-gradient(ellipse at 0% 0%, rgba(20,0,255,.92), transparent 52%),
        radial-gradient(ellipse at 100% 100%, rgba(20,0,255,.75), transparent 52%);
      background-size:10px 17.32px,10px 17.32px,100% 100%,210% 210%,210% 210%;
      background-position:0 0,5px 8.66px,center,0% 0%,100% 100%;
      animation:edge-orbit 14s linear infinite;
    }
    @keyframes edge-orbit{
      0%  {background-position:0 0,5px 8.66px,center,  0%   0%,100% 100%;}
      25% {background-position:0 0,5px 8.66px,center,100%   0%,  0% 100%;}
      50% {background-position:0 0,5px 8.66px,center,100% 100%,  0%   0%;}
      75% {background-position:0 0,5px 8.66px,center,  0% 100%,100%   0%;}
      100%{background-position:0 0,5px 8.66px,center,  0%   0%,100% 100%;}
    }
    .hero-line{position:absolute;left:0;right:0;bottom:0;height:1px;background:linear-gradient(to right,transparent,#1400FF 30%,#00CFFF 70%,transparent);opacity:.4;}

    /* ── Sec number ── */
    .sec-num{font-size:clamp(5rem,15vw,10rem);font-weight:700;color:#1a1a1a;line-height:1;user-select:none;}

    /* ── About ── */
    .holo-logo{animation:holo-float 6s ease-in-out infinite;filter:drop-shadow(0 0 30px rgba(0,207,255,.4));}
    @keyframes holo-float{0%,100%{transform:translateY(0) rotate(-2deg);}50%{transform:translateY(-20px) rotate(2deg);}}
    @media(max-width:768px){
      .holo-logo{display:none!important;}
      .about-grid{grid-template-columns:1fr!important;gap:2rem!important;}
    }

    /* ── Content cards ── */
    .content-cards{display:grid;gap:2rem;}
    .content-card{
      background:var(--surface);border:1px solid #1e1e1e;border-radius:10px;padding:2.5rem;
      position:relative;overflow:hidden;
      opacity:0;transform:translateY(44px) scale(.98);
      transition:opacity 600ms ease-out,transform 600ms ease-out,box-shadow 300ms,border-color 300ms;
    }
    .content-card.visible{opacity:1;transform:translateY(0) scale(1);}
    .content-card:hover{border-color:#2a2a2a;box-shadow:0 24px 64px rgba(0,0,0,.45);}
    .content-card::before{
      content:'';position:absolute;inset:0;border-radius:10px;
      background:radial-gradient(ellipse at top left,rgba(20,0,255,.06) 0%,transparent 60%);
      pointer-events:none;
    }

    .card-icon-wrap{
      width:56px;height:56px;border-radius:12px;
      background:rgba(20,0,255,.1);border:1px solid rgba(20,0,255,.25);
      display:flex;align-items:center;justify-content:center;
      margin-bottom:1.75rem;flex-shrink:0;
    }

    .card-header{display:flex;align-items:flex-start;gap:1.5rem;margin-bottom:1.75rem;}
    .card-num{font-size:3.5rem;font-weight:700;color:rgba(20,0,255,.06);line-height:1;user-select:none;flex-shrink:0;margin-top:-.25rem;}
    .card-title{font-size:clamp(1.1rem,2.2vw,1.45rem);font-weight:700;text-transform:uppercase;letter-spacing:.03em;margin:0;line-height:1.2;}

    .card-deliverables{border-top:1px solid #1a1a1a;padding-top:1.5rem;margin-top:1.5rem;}
    .check-item{display:flex;align-items:flex-start;gap:.6rem;margin-bottom:.55rem;}
    .check-icon{color:var(--blue);flex-shrink:0;margin-top:2px;font-size:.9rem;}

    .card-price-block{border-top:1px solid #1a1a1a;padding-top:1.5rem;margin-top:1.75rem;}
    .card-price-label{font-size:.62rem;letter-spacing:.16em;text-transform:uppercase;color:#555;margin:0 0 .4rem;}
    .card-price{font-size:clamp(2rem,4vw,2.8rem);font-weight:700;color:#fff;line-height:1;}

    /* Sub-option cards (Card 2) */
    .card-options{display:grid;grid-template-columns:1fr 1fr;gap:1rem;border-top:1px solid #1a1a1a;padding-top:1.5rem;margin-top:1.75rem;}
    @media(max-width:500px){.card-options{grid-template-columns:1fr;}}
    .card-option{
      background:#0d0d0d;border:1px solid #1e1e1e;border-radius:8px;padding:1.25rem 1.5rem;
      text-align:center;transition:border-color 250ms,background 250ms,transform 200ms;cursor:default;
    }
    .card-option:hover{border-color:rgba(20,0,255,.5);background:rgba(20,0,255,.07);transform:translateY(-2px);}
    .card-option-name{font-size:.75rem;color:#777;letter-spacing:.04em;line-height:1.4;margin:0 0 .8rem;}
    .card-option-price{font-size:1.7rem;font-weight:700;color:var(--cyan);line-height:1;}

    /* Promo badge (Card 3) */
    .card-badge{
      display:inline-flex;align-items:center;gap:.5rem;
      margin-top:1.25rem;padding:.55rem 1rem;
      background:rgba(0,207,255,.07);border:1px solid rgba(0,207,255,.25);
      border-radius:6px;font-size:.78rem;color:var(--cyan);line-height:1.4;
    }
    .badge-dot{width:7px;height:7px;border-radius:50%;background:var(--cyan);flex-shrink:0;animation:dot-pulse 2s ease-in-out infinite;}

    /* ── Hero scroll btn ── */
    .hero-scroll-btn{display:inline-flex;align-items:center;gap:.55rem;padding:.6rem 1.4rem;border:1px solid #252525;border-radius:999px;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:#484848;background:transparent;cursor:pointer;font-family:inherit;transition:border-color 300ms,color 300ms,transform 300ms;}
    .hero-scroll-btn:hover{border-color:#555;color:#aaa;transform:translateY(2px);}
    .hero-scroll-arrow{animation:arrow-bounce 1.8s ease-in-out infinite;}
    @keyframes arrow-bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(4px)}}

    /* ── CTA ── */
    .cta-btn{display:inline-block;background:var(--blue);color:#fff;font-family:inherit;font-size:1rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;text-decoration:none;padding:1rem 2.5rem;border-radius:4px;transition:filter 200ms,transform 200ms;}
    .cta-btn:hover{filter:brightness(1.2);transform:scale(1.02);}
    .cta-btn-pulse{animation:cta-pulse 1.6s ease-in-out infinite;}
    @keyframes cta-pulse{0%,100%{box-shadow:0 0 0 0 rgba(20,0,255,.6),0 0 20px rgba(20,0,255,.3);}50%{box-shadow:0 0 0 10px rgba(20,0,255,0),0 0 30px rgba(20,0,255,.15);}}

    /* ── label ── */
    .label{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--cyan);font-weight:500;}

    /* Meta row */
    .hero-meta{display:flex;align-items:center;justify-content:center;gap:1.5rem;flex-wrap:wrap;font-size:.75rem;letter-spacing:.06em;color:#444;margin-bottom:2.5rem;}
    .hero-meta-sep{width:1px;height:12px;background:#222;}
  </style>
</head>
<body class="grain">

<!-- ════════════════════════════════════════════════
     1. HERO — Conteúdo (conciso)
════════════════════════════════════════════════ -->
<section style="min-height:85vh;display:flex;align-items:center;justify-content:center;position:relative;padding:5rem 2rem;overflow:hidden;">

  <div class="hero-bg">
    <div class="hero-dots"></div>
  </div>
  <div class="hero-line"></div>

  <!-- Validade (canto) -->
  <div style="position:absolute;top:2rem;right:2rem;color:#333;font-size:.72rem;letter-spacing:.06em;z-index:2;text-align:right;">
    Válida até <span style="color:#555;"><%= proposal.expiresAt %></span>
  </div>

  <div style="text-align:center;max-width:760px;width:100%;position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;">

    <!-- Logo -->
    <div class="hero-item" style="margin-bottom:3rem;">
      <% if (assets.logoHup.length) { %>
        <img src="<%= assets.logoHup.find(l=>l.toLowerCase().includes('branca'))||assets.logoHup[0] %>"
             alt="HUP Creative" style="height:72px;width:auto;display:inline-block;filter:drop-shadow(0 0 24px rgba(20,0,255,.45));">
      <% } %>
    </div>

    <!-- Badge -->
    <div class="hero-item hero-badge-pill">
      <span class="hero-badge-dot"></span>
      Proposta Comercial&nbsp;&nbsp;·&nbsp;&nbsp;<strong style="color:#aaa;font-weight:600;letter-spacing:.06em;"><%= proposal.serviceType %></strong>
    </div>

    <!-- Título -->
    <h1 class="hero-item" style="font-family:'Poppins',sans-serif;font-size:clamp(2.4rem,6vw,5rem);font-weight:800;line-height:1.1;margin:0 0 1.25rem;text-align:center;">
      <%= proposal.client.company %>,<br>
      <span style="background:linear-gradient(90deg,var(--blue),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-style:italic;">conteúdo que impacta.</span>
    </h1>

    <!-- Cliente + datas -->
    <div class="hero-item hero-meta">
      <span style="color:#888;font-weight:500;letter-spacing:.04em;"><%= proposal.client.contact %></span>
      <span class="hero-meta-sep"></span>
      <span>Emitida em <span id="emission-date" style="color:#555;"></span></span>
      <span class="hero-meta-sep"></span>
      <span>Válida até <span style="color:#555;"><%= proposal.expiresAt %></span></span>
    </div>

    <!-- Scroll -->
    <button class="hero-item hero-scroll-btn" onclick="window.scrollBy({top:window.innerHeight*.85,behavior:'smooth'})">
      Ver proposta
      <svg class="hero-scroll-arrow" width="13" height="13" viewBox="0 0 13 13" fill="none">
        <path d="M6.5 1.5v10M2 8l4.5 4.5L11 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

  </div>
</section>

<!-- ════════════════════════════════════════════════
     2. QUEM SOMOS
════════════════════════════════════════════════ -->
<section class="section" style="border-top:1px solid #111;overflow:hidden;">
  <div class="container">
    <div class="about-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;">
      <div>
        <div style="display:flex;align-items:center;gap:1.5rem;margin-bottom:3rem;">
          <div class="sec-num reveal">02</div>
          <p class="label reveal">Quem somos</p>
        </div>
        <h2 class="reveal" style="font-size:clamp(1.8rem,3.5vw,3rem);font-weight:700;text-transform:uppercase;margin:0 0 2rem;line-height:1.1;">
          We Make it<br><span style="color:var(--cyan);">Happen!</span>
        </h2>
        <div style="color:#aaa;line-height:1.9;font-size:.92rem;">
          <p class="reveal" style="margin:0 0 1.25rem;">
            Somos a nova geração que não conhece o mundo sem internet e acredita na sinergia entre on e off. Somos ligados no 220, múltiplos e simultâneos.
          </p>
          <p class="reveal" style="margin:0 0 1.25rem;">
            A HUP nasceu da necessidade em saber se comunicar numa realidade cada vez mais dinâmica e multimidiática, unindo estratégia e criatividade na personalidade de cada marca.
          </p>
          <p class="reveal" style="margin:0;">
            Oferecemos uma entrega 360°: do planejamento estratégico à produção de fotografia e audiovisual.
          </p>
        </div>
      </div>
      <div class="reveal" style="display:flex;align-items:center;justify-content:center;">
        <% const holoSrc = assets.logoHup.find(l=>l.toLowerCase().includes('holo')) || assets.logoHup[0]; %>
        <img class="holo-logo" src="<%= holoSrc %>" alt="HUP Holográfica" style="max-width:320px;width:100%;height:auto;">
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════════
     3. ENTREGAS — Cards de conteúdo
════════════════════════════════════════════════ -->
<section class="section" style="border-top:1px solid #111;">
  <div class="container">

    <div style="margin-bottom:3.5rem;">
      <div class="sec-num reveal" style="float:left;margin-right:1.5rem;line-height:.85;">03</div>
      <p class="label reveal" style="margin-bottom:.5rem;">Proposta para <%= proposal.client.company %></p>
      <h2 class="reveal" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;margin:0;line-height:1.1;clear:both;">Entregas</h2>
    </div>

    <!-- SVG gradient defs (reutilizado pelos ícones) -->
    <svg width="0" height="0" style="position:absolute;overflow:hidden;" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="icon-g" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#1400FF"/>
          <stop offset="100%" stop-color="#00CFFF"/>
        </linearGradient>
      </defs>
    </svg>

    <div class="content-cards">

      <% proposal.cards.forEach((card, idx) => { %>
      <div class="content-card" data-card-idx="<%= idx %>">

        <div class="card-header">
          <!-- Ícone SVG por tipo -->
          <div class="card-icon-wrap">
            <% if (card.icon === 'video') { %>
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1.5" y="5.5" width="17" height="17" rx="2" stroke="url(#icon-g)" stroke-width="1.6"/>
                <path d="M18.5 10.5L26.5 7v14l-8-3.5V10.5z" stroke="url(#icon-g)" stroke-width="1.6" stroke-linejoin="round"/>
                <line x1="6" y1="10" x2="6" y2="18" stroke="url(#icon-g)" stroke-width="1.6" stroke-linecap="round"/>
                <line x1="9.5" y1="8" x2="9.5" y2="20" stroke="url(#icon-g)" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
            <% } else if (card.icon === 'camera') { %>
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M2 9c0-1.1.9-2 2-2h3.5l2.5-3h8l2.5 3H24c1.1 0 2 .9 2 2v14c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V9z" stroke="url(#icon-g)" stroke-width="1.6"/>
                <circle cx="14" cy="16" r="4.5" stroke="url(#icon-g)" stroke-width="1.6"/>
                <circle cx="14" cy="16" r="1.5" fill="url(#icon-g)"/>
                <circle cx="22" cy="10" r="1" fill="url(#icon-g)"/>
              </svg>
            <% } else if (card.icon === 'social') { %>
              <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="2" y="16" width="5" height="10" rx="1" stroke="url(#icon-g)" stroke-width="1.6"/>
                <rect x="11.5" y="9" width="5" height="17" rx="1" stroke="url(#icon-g)" stroke-width="1.6"/>
                <rect x="21" y="3" width="5" height="23" rx="1" stroke="url(#icon-g)" stroke-width="1.6"/>
                <path d="M4.5 12L14 6l7 3.5 4.5-4" stroke="url(#icon-g)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            <% } %>
          </div>

          <div style="flex:1;">
            <div class="card-num"><%= card.id %></div>
            <h3 class="card-title"><%= card.name %></h3>
          </div>
        </div>

        <!-- Deliverables -->
        <div class="card-deliverables">
          <% card.deliverables.forEach(d => { %>
            <div class="check-item">
              <span class="check-icon">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7.5l3.5 3.5 6.5-7" stroke="#1400FF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <span style="color:#bbb;font-size:.88rem;line-height:1.6;"><%= d %></span>
            </div>
          <% }) %>
        </div>

        <!-- Preço único -->
        <% if (card.price) { %>
          <div class="card-price-block">
            <p class="card-price-label"><%= card.priceLabel || 'Investimento' %></p>
            <div class="card-price"><%= card.price %></div>
          </div>
        <% } %>

        <!-- Badge promo (Card 3) -->
        <% if (card.badge) { %>
          <div class="card-badge">
            <span class="badge-dot"></span>
            <span><%= card.badge %></span>
          </div>
        <% } %>

        <!-- Sub-opções (Card 2) -->
        <% if (card.options && card.options.length) { %>
          <div class="card-options">
            <% card.options.forEach(opt => { %>
              <div class="card-option">
                <p class="card-option-name"><%= opt.name %></p>
                <div class="card-option-price"><%= opt.price %></div>
              </div>
            <% }) %>
          </div>
          <p style="font-size:.7rem;color:#444;letter-spacing:.06em;margin:.9rem 0 0;text-align:center;">por turno de captação</p>
        <% } %>

      </div>
      <% }) %>

    </div>

    <!-- CTA imediato após os cards -->
    <div style="text-align:center;margin-top:3.5rem;">
      <a href="<%= proposal.cta.meetingLink %>" target="_blank"
         class="cta-btn-pulse"
         style="display:inline-block;background:var(--blue);color:#fff;font-family:inherit;font-size:.85rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;text-decoration:none;padding:.9rem 2.4rem;border-radius:4px;transition:filter 200ms;">
        Quero avançar com esse projeto ↗
      </a>
    </div>

  </div>
</section>

<!-- ════════════════════════════════════════════════
     4. CTA FINAL
════════════════════════════════════════════════ -->
<section class="section" style="border-top:1px solid #111;text-align:center;">
  <div class="container" style="max-width:600px;">
    <p class="label reveal" style="margin-bottom:1rem;">Próximo passo</p>
    <h2 class="reveal" style="font-size:clamp(1.8rem,4vw,3rem);font-weight:700;text-transform:uppercase;margin:0 0 2.5rem;line-height:1.1;">
      Vamos<br><span style="color:var(--cyan);">Conversar?</span>
    </h2>
    <div class="reveal" style="margin-bottom:2rem;">
      <a href="<%= proposal.cta.meetingLink %>" target="_blank" class="cta-btn">Agendar reunião ↗</a>
    </div>
    <div class="reveal" style="color:#444;font-size:.85rem;line-height:2.2;">
      <% if(proposal.cta.whatsapp){ %>
        <div>WhatsApp: <a href="https://wa.me/<%= proposal.cta.whatsapp.replace(/\D/g,'') %>" style="color:#666;text-decoration:none;" target="_blank"><%= proposal.cta.whatsapp %></a></div>
      <% } %>
      <% if(proposal.cta.email){ %>
        <div>E-mail: <a href="mailto:<%= proposal.cta.email %>" style="color:#666;text-decoration:none;"><%= proposal.cta.email %></a></div>
      <% } %>
    </div>
  </div>
</section>

<footer style="border-top:1px solid #111;padding:2rem;text-align:center;color:#222;font-size:.72rem;letter-spacing:.06em;">
  © <%= new Date().getFullYear() %> HUP Creative — hupcreative.cloud
</footer>

<!-- ════════════════════════════════════════════════
     JS
════════════════════════════════════════════════ -->
<script>
  // ── Data de emissão ────────────────────────────
  (function(){
    const el = document.getElementById('emission-date');
    if(!el) return;
    const d = new Date();
    el.textContent = d.toLocaleDateString('pt-BR', {day:'2-digit',month:'2-digit',year:'numeric'});
  })();

  // ── Scroll reveal ──────────────────────────────
  const revObs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');revObs.unobserve(e.target);}});
  },{threshold:0.06});
  document.querySelectorAll('.reveal').forEach(el=>revObs.observe(el));

  // ── Hero entrance ──────────────────────────────
  document.querySelectorAll('.hero-item').forEach((el,i)=>{
    setTimeout(()=>el.classList.add('visible'), 120 + i * 180);
  });

  // ── Content cards stagger ─────────────────────
  const cardObs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        setTimeout(()=>e.target.classList.add('visible'), parseInt(e.target.dataset.cardIdx||0)*200);
        cardObs.unobserve(e.target);
      }
    });
  },{threshold:0.06});
  document.querySelectorAll('.content-card').forEach(el=>cardObs.observe(el));
</script>
</body>
</html>
